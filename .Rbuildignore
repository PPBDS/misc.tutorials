^renv$
^renv\.lock$
^\.Rproj\.user$
^LICENSE\.md$
^TODO.txt$
^_pkgdown\.yml$
^docs$
^pkgdown$
^\.github$
^README.Rmd$
^README.html$
^CRAN-SUBMISSION$
^inst/tutorials/.*\.html$
^inst/tutorials/.*_files(/.*)?$
^CLAUDE.md$
^\.claude$

# Uncomment this line when submitting to CRAN. We do so to remove the
# per-tutorial data directories under inst/extdata/ (these files are large); it
# keeps inst/extdata/README.txt. On a stripped install, R/zzz.R's .onAttach()
# re-downloads the missing files from GitHub. Note that R CMD check will still
# show the package as large because it does not report the .tar.gz file size,
# which is what matters to CRAN.
# ^inst/extdata/[^/]+/
